# ZN M2 设备配置文件
# 作者: 李杰
# 设备型号: ZN M2
# 硬件平台: Qualcomm IPQ60XX
# 硬件规格:
# - CPU: Qualcomm IPQ6010
# - RAM: 256MB
# - Flash: 128MB
# - 网口: 4个千兆LAN口, 1个千兆WAN口
# - WiFi: 2.4G + 5G 双频
# - 其他: 无

# 编译配置
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_zn_m2=y

# 固件版本
CONFIG_VERSION_NUMBER="1.0.0"
CONFIG_VERSION_CODE="20260328"

# 编译参数
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"
CONFIG_TARGET_SUFFIX="nss"

# 网络配置
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-ddns=y

# WiFi配置
CONFIG_PACKAGE_luci-app-wifi-config=y
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y

# 系统工具
CONFIG_PACKAGE_luci-app-sysinfo=y
CONFIG_PACKAGE_luci-app-autoreboot=y

# 第三方插件
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-control-weburl=y
CONFIG_PACKAGE_luci-app-control-timewol=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-parentcontrol=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_ariang=y
