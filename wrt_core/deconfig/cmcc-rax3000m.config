# CMCC RAX3000M 设备配置文件（优化版）
# 作者: 李杰
# 设备型号: CMCC RAX3000M
# 硬件平台: MediaTek Filogic
# 版本: 2.0
# 更新日期: 2026-04-02

# ==================== 硬件规格 ====================
# CPU: MediaTek MT7986A (4核 Cortex-A53 @ 1.3GHz)
# RAM: 512MB DDR4
# Flash: 128MB SPI NAND
# 网口: 4个千兆LAN口, 1个千兆WAN口
# WiFi: 2.4G (MT7975) + 5G (MT7976) 双频WiFi 6
# 其他: USB 3.0 x1, M.2 NVMe插槽

# ==================== 目标平台配置 ====================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_cmcc_rax3000m=y
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_filogic_DEVICE_cmcc_rax3000m=""

# ==================== 固件版本信息 ====================
CONFIG_VERSION_NUMBER="2.0.0"
CONFIG_VERSION_CODE="20260402"
CONFIG_VERSION_DIST="OpenWrt"
CONFIG_VERSION_REPO="https://github.com/LiBwrt/openwrt-6.x"
CONFIG_VERSION_MANUFACTURER="LiJie"
CONFIG_VERSION_PRODUCT="CMCC RAX3000M"
CONFIG_VERSION_HWREV="v1.0"

# ==================== 编译优化参数 ====================
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"
CONFIG_USE_UCLIBCXX=y
CONFIG_USE_GLIBC=y
CONFIG_USE_MKLIBS=y

